# SG_CUBE environment template. Copy to .env and fill in.
# .env is git-ignored. .env.example is checked in.

# ── App ──
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8001

# ── Supabase (Phase 2) ──
# From Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
# From Supabase Dashboard → Project Settings → API → JWT Settings (legacy JWT secret)
SUPABASE_JWT_SECRET=your_jwt_secret

# ── Ollama (local intent classifier + embeddings) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# ── OpenRouter (optional — recommended future direction: DeepSeek V3) ──
# Get key at https://openrouter.ai/keys
# When you switch, uncomment both lines below and comment out the two
# GEMINI_* lines further down. DeepSeek V3 is the recommended model for
# this project: strong JSON / tool-use, competitive chat quality, cheapest
# of the open-source frontier tier. Alternates: moonshotai/kimi-k2,
# qwen/qwen3-72b-instruct.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=deepseek/deepseek-chat

# ── Gemini (current default) ──
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Whisper (Phase 3) ──
WHISPER_MODEL=base

# ── Phase C3: LiveKit optional voice pipeline ──
# VOICE_PIPELINE=local|livekit
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your_api_key
# LIVEKIT_API_SECRET=your_api_secret
